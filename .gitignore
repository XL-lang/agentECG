# Keep the dataset directory visible in the repo while ignoring dataset contents.
dataset/**
!dataset/
!dataset/__init__.py
!dataset/config.py
!dataset/load_dataset.sh
!dataset/test.md

# Python cache and local notebook artifacts.
__pycache__/
*.pyc
.ipynb_checkpoints/

# Runtime logs and ad-hoc local outputs.
*.log
app.log
*.png
!docs/images/agentecg-web-*.png
ecg_output.png

# Model artifacts and serialized training outputs.
*.pkl
*.pth
test_results.json
models/pytorch_inception/output/
utils/model.yaml

# Test and experiment outputs.
test_tools/results/
tmp/*.log
tmp/*.csv
tmp/*results*.json
tmp/web_agent_memories.json
tmp/web_snapshots/
tmp/web_uploads/
tmp/ecgdeli_example_out/
tmp/ecgdeli_granular_*/
tmp/ecgdeli_run_*/

# Sample input data kept local.
example_ecg/*

# External tool checkouts and local binary installers.
external/
